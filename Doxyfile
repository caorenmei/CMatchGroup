# 代码提取
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES

# 中文支持
DOXYFILE_ENCODING      = UTF-8
INPUT_ENCODING         = UTF-8

# 主题与样式
HTML_TIMESTAMP         = YES
