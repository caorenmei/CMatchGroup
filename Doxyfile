# Doxygen 配置文件

PROJECT_NAME           = "CMatchGroup"
PROJECT_NUMBER         = "0.1.0"
PROJECT_BRIEF          = "C++20 项目模板文档"
OUTPUT_DIRECTORY       = docs/generated
INPUT                  = README.md include src
FILE_PATTERNS          = *.h *.cpp *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = README.md

# 输出格式
GENERATE_HTML          = YES
